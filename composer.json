{
    "name": "waqassiwag/laravel-variant-generator",
    "description": "A Laravel package to generate all possible product variants (Cartesian Product) from a set of attributes.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Muhammad Waqas Software Engineer",
            "email": "m.waqas7375@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/collections": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "phpstan/phpstan": "^1.10",
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\VariantGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\VariantGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\VariantGenerator\\VariantGeneratorServiceProvider"
            ],
            "aliases": {
                "VariantGenerator": "Vendor\\VariantGenerator\\Facades\\VariantGenerator"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage",
        "analyse": "phpstan analyse",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}